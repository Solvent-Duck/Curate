{
  "manifest_version": 2,
  "name": "Curate",
  "version": "1.0.0",
  "description": "Maintain a blacklist of terms to block unwanted content from webpages",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Curate - Content Filter"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
